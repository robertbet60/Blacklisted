# Copy this file to `.env` to configure the scanner.
# Nothing here is required to run — everything has sensible defaults.

# ---- Server ----
PORT=8000

# ---- Poller tuning ----
POLL_INTERVAL=60                # seconds between crt.sh cycles
TELEGRAM_POLL_INTERVAL=300      # seconds between Telegram scrape cycles

# ---- Telegram channels (override the built-in seed list) ----
# Comma-separated handles, no @ prefix
# TELEGRAM_CHANNELS=apostasepalpites,aposta10,sinais_telegram

# ---- Supabase (optional — enables persistence) ----
# Get these from supabase.com → your project → Settings → API
# SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ---- Optional Brazilian proxy for the site-fetch step ----
# If hosting outside Brazil, route only the page-fetch through a BR proxy.
# BR_PROXY_URL=http://user:pass@proxy.host:port
